+    /* test UnlockFileEx with overlapped event signaling */
+    {
+        HANDLE event = CreateEventA( NULL, TRUE, FALSE, NULL );
+        ok( event != NULL, "CreateEvent failed\n" );
+
+        overlapped.Offset = 0;
+        overlapped.OffsetHigh = 0;
+        overlapped.hEvent = event;
+
+        ok( LockFileEx( handle, LOCKFILE_EXCLUSIVE_LOCK, 0, 100, 0, &overlapped ),
+            "LockFileEx 0,100 failed\n" );
+
+        ResetEvent( event );
+        ok( UnlockFileEx( handle, 0, 100, 0, &overlapped ), "UnlockFileEx 0,100 failed\n" );
+        ret = WaitForSingleObject( event, 0 );
+        ok( ret == WAIT_OBJECT_0, "event not signaled after UnlockFileEx, got %ld\n", ret );
+
+        /* test with low bit set (skip IOCP notification flag) */
+        ok( LockFileEx( handle, LOCKFILE_EXCLUSIVE_LOCK, 0, 100, 0, &overlapped ),
+            "LockFileEx 0,100 failed\n" );
+
+        ResetEvent( event );
+        overlapped.hEvent = (HANDLE)((ULONG_PTR)event | 1);
+        ok( UnlockFileEx( handle, 0, 100, 0, &overlapped ), "UnlockFileEx 0,100 failed\n" );
+        ret = WaitForSingleObject( event, 0 );
+        ok( ret == WAIT_OBJECT_0, "event not signaled after UnlockFileEx with low bit set, got %ld\n", ret );
+
+        overlapped.hEvent = 0;
+        CloseHandle( event );
+    }
+
+    /* test LockFileEx posts I/O completion */
+    {
+        HANDLE iocp_file, port, event;
+        ULONG_PTR key_out;
+        DWORD bytes;
+        LPOVERLAPPED ov_out;
+
+        event = CreateEventA( NULL, TRUE, FALSE, NULL );
+        ok( event != NULL, "CreateEvent failed\n" );
+
+        iocp_file = CreateFileA( filename, GENERIC_READ | GENERIC_WRITE,
+                                 FILE_SHARE_READ | FILE_SHARE_WRITE, NULL,
+                                 OPEN_EXISTING, FILE_FLAG_OVERLAPPED, 0 );
+        ok( iocp_file != INVALID_HANDLE_VALUE, "CreateFile failed, err=%lu\n", GetLastError() );
+
+        port = CreateIoCompletionPort( iocp_file, NULL, 0x12345, 1 );
+        ok( port != NULL, "CreateIoCompletionPort failed, err=%lu\n", GetLastError() );
+
+        memset( &overlapped, 0, sizeof(overlapped) );
+        overlapped.hEvent = event;  /* low bit clear, post to IOCP */
+
+        ret = LockFileEx( iocp_file, LOCKFILE_EXCLUSIVE_LOCK, 0, 100, 0, &overlapped );
+        ok( ret, "LockFileEx failed, err=%lu\n", GetLastError() );
+
+        ov_out = NULL;
+        key_out = 0;
+        bytes = 0xdeadbeef;
+        ret = GetQueuedCompletionStatus( port, &bytes, &key_out, &ov_out, 0 );
+        ok( ret, "GetQueuedCompletionStatus failed, err=%lu\n", GetLastError() );
+        ok( key_out == 0x12345, "wrong key %lx\n", (unsigned long)key_out );
+        ok( ov_out == &overlapped, "wrong overlapped %p\n", ov_out );
+
+        ok( UnlockFileEx( iocp_file, 0, 100, 0, &overlapped ), "UnlockFileEx failed\n" );
+
+        /* low bit set on hEvent skips IOCP notification */
+        overlapped.hEvent = (HANDLE)((ULONG_PTR)event | 1);
+        ret = LockFileEx( iocp_file, LOCKFILE_EXCLUSIVE_LOCK, 0, 100, 0, &overlapped );
+        ok( ret, "LockFileEx failed, err=%lu\n", GetLastError() );
+
+        ov_out = NULL;
+        ret = GetQueuedCompletionStatus( port, &bytes, &key_out, &ov_out, 0 );
+        ok( !ret, "GetQueuedCompletionStatus should have failed (no completion expected)\n" );
+        ok( GetLastError() == WAIT_TIMEOUT, "expected WAIT_TIMEOUT, got %lu\n", GetLastError() );
+
+        overlapped.hEvent = 0;
+        ok( UnlockFileEx( iocp_file, 0, 100, 0, &overlapped ), "UnlockFileEx failed\n" );
+
+        CloseHandle( port );
+        CloseHandle( event );
+        CloseHandle( iocp_file );
+    }
+
     CloseHandle( handle2 );
 cleanup:
     CloseHandle( handle );
     DeleteFileA( filename );
